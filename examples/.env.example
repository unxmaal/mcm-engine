# Copy to examples/.env and edit. Used by examples/docker-compose.yml.

# Postgres password for the bundled database. Required.
POSTGRES_PASSWORD=change-me

# Host values clients reach the daemon by, comma or space separated (the
# published LAN IP or DNS name). Required past the MCP DNS-rebinding guard,
# which rejects unknown Host headers with 421. Loopback is always allowed.
# Example: 192.168.8.88
ALLOWED_HOSTS=
